page {
  background: linear-gradient(180deg, #f1f8f6 0%, #eef4ff 100%);
  color: #1e293b;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.08);
}

.section-title {
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.helper {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.btn-primary {
  border-radius: 999rpx;
  background: linear-gradient(165deg, #14b8a6 0%, #0d9488 60%, #0f766e 100%);
  color: #fff;
  border: none;
  font-size: 28rpx;
}

.btn-secondary {
  border-radius: 999rpx;
  border: 1rpx solid #94a3b8;
  color: #334155;
  background: #fff;
  font-size: 26rpx;
}

.error {
  margin-top: 16rpx;
  background: #fff1f2;
  border: 1rpx solid #fecdd3;
  color: #be123c;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
}

.warn {
  margin-top: 16rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  color: #92400e;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
}
