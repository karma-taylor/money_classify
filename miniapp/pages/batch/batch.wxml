<view class="container">
  <view class="card">
    <view class="section-title">批量 Excel 处理</view>
    <view class="helper">读取首个工作表，按 A=姓名、B=薪水重算五种面额（50000~1000）。</view>

    <view class="section-label">当前可用面额</view>
    <view class="denom-chips">
      <view class="chip" wx:for="{{selectedDenomLabels}}" wx:key="*this">{{item}}</view>
    </view>

    <view class="btn-row">
      <button class="btn-secondary" bindtap="pickExcel">导入 Excel</button>
      <button class="btn-secondary" bindtap="recalc" disabled="{{!hasImported}}">按面额重算</button>
      <button class="btn-primary btn-row-span" bindtap="exportExcel" disabled="{{!rows.length}}">导出 Excel</button>
    </view>

    <view wx:if="{{statusMsg}}" class="helper status">{{statusMsg}}</view>
    <view wx:if="{{errorMsg}}" class="error">{{errorMsg}}</view>
  </view>

  <view class="card" wx:if="{{rows.length}}">
    <view class="section-title">预览（{{rows.length}} 人）</view>
    <scroll-view class="table-wrap" scroll-x="true">
      <view class="table table-header">
        <text>姓名</text><text>薪水</text><text>50000</text><text>25000</text><text>10000</text><text>5000</text><text>1000</text><text>余数</text>
      </view>
      <view class="table" wx:for="{{rows}}" wx:key="name">
        <text>{{item.name}}</text>
        <text>{{item.salaryLabel}}</text>
        <text>{{item.c50000}}</text>
        <text>{{item.c25000}}</text>
        <text>{{item.c10000}}</text>
        <text>{{item.c5000}}</text>
        <text>{{item.c1000}}</text>
        <text>{{item.remainderLabel}}</text>
      </view>
    </scroll-view>
  </view>
</view>
